# 萤石开放平台凭证（生产环境请使用真实值，勿提交 .env）
EZVIZ_ACCESS_TOKEN=

# 仓鼠分析 SQLite
PET_ANALYSIS_DB_PATH=pet_analysis.db
PET_UPLOAD_DIR=upload

# RAG / LLM（DeepSeek 等 OpenAI 兼容接口）
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=dsv4

# RAG 向量库
RAG_DATA_DIR=data
CHROMA_PERSIST_DIR=chroma_db
CHROMA_COLLECTION_NAME=yingshi_rag
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TRANSLATE_MODEL=qwen2.5:0.5b
OLLAMA_LLM_MODEL=qwen2.5:0.5b
