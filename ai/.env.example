# 萤石开放平台凭证（生产环境请使用真实值，勿提交 .env）
EZVIZ_ACCESS_TOKEN=

# 仓鼠分析 SQLite
PET_ANALYSIS_DB_PATH=pet_analysis.db
PET_UPLOAD_DIR=upload

# ── RAG / LLM（DeepSeek 等 OpenAI 兼容接口）──
# DeepSeek API (required for query rewrite, rerank, and answer generation)
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=dsv4

# ── RAG 向量库 ──
RAG_DATA_DIR=data
CHROMA_PERSIST_DIR=chroma_db
CHROMA_COLLECTION_NAME=yingshi_rag

# Ollama (embedding + local LLM)
# Local dev: http://127.0.0.1:11434
# Docker:    http://ollama:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TRANSLATE_MODEL=qwen2.5:0.5b
OLLAMA_LLM_MODEL=qwen2.5:0.5b

# ── Day 0: Chunking & Retrieval ──
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=12
RAG_MAX_DISTANCE=1.5  # P95-based; run scripts/analyze_distances.py to calibrate
RAG_QUERY_TRANSLATION=true

# ── Day 1: Query Rewrite (DeepSeek coref + multi-query + keywords) ──
# Enable after eval baseline shows coref improvement.
RAG_QUERY_REWRITE_ENABLED=true
RAG_QUERY_REWRITE_MAX_QUERIES=3

# ── Day 2: Hybrid RAG (BM25 + Vector with RRF fusion) ──
# Requires jieba + rank-bm25. Custom dictionary: data/hamster_dict.txt
RAG_HYBRID_ENABLED=true
RAG_VECTOR_TOP_N=20
RAG_BM25_TOP_N=20
RAG_RRF_K=60

# ── Day 3: LLM Reranker ──
# LLM-based (DeepSeek); cross-encoder when torch/sentence-transformers available
RAG_RERANK_ENABLED=true
RAG_RERANK_BACKEND=llm
RAG_RERANK_TOP_N=5
RAG_RERANK_CANDIDATE_N=20

# ── Agent Mode: LLM autonomously decides which tools to call ──
# true → Agent path (LLM tool-calling: search_kb, lookup_facts, get_user_context, etc.)
# false → Fixed RAG pipeline (default, backward-compatible)
RAG_AGENT_ENABLED=false

# ── Eval (golden set: data/eval/questions.jsonl, 17 questions) ──
# Baseline (vector only):     Recall@10=52.94%  MRR@10=0.35
# Full pipeline (Day 3):     Recall@10=100.00%  MRR@10=0.97
# Run: poetry run python scripts/eval_rag.py --full-pipeline
